#!/bin/bash --login
#SBATCH --time=24:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --mem=128G
#SBATCH --job-name=bootstrap
#SBATCH -A glbrc

cd "$SLURM_SUBMIT_DIR"
cores="$SLURM_CPUS_PER_TASK"

echo -e "Running: bootstrap.sb\n from MAFFT alignment"

# Load modules
module purge
module load Miniforge3
conda activate raxmlNG

# Define paths
INPUT_DIR="/mnt/home/benucci/Phylogenetics/Phylogeny_with_RAXml/mafft/results"
OUTPUT_DIR="/mnt/home/benucci/Phylogenetics/Phylogeny_with_RAXml/mafft/results"

# Create output directory if it doesn't exist
mkdir -p "$OUTPUT_DIR"

# Run ModelTETS-ng
raxml-ng \
	--bootstrap \
        --msa "${INPUT_DIR}/otus99_mafft_trim.fasta" \
	--model GTR+G4 \
	--bs-trees 500 \
	--threads $cores \
	--seed 2602 \
       --prefix "${OUTPUT_DIR}/otus99_mafft_trim_bs"

echo -e "\n========== Job Summary ==========\n"
echo -e "Working directory: $(pwd)"
echo -e "Threads used: $cores\n"

echo -e "\n========== Sbatch log ==========\n"
sacct -u "$USER" -j "$SLURM_JOB_ID" --format=JobID,JobName,Start,End,Elapsed,NCPUS
echo -e "\n"
scontrol show job "$SLURM_JOB_ID"
